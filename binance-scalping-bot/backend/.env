APP_NAME=Binance Scalping Bot API
APP_ENV=development
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173
SQLITE_DB_PATH=/Users/thang/Desktop/TEST/binance-scalping-bot/backend/backend_data/trading_bot.db
LIQUID_ML_MODEL_PATH=/Users/thang/Desktop/TEST/binance-scalping-bot/backend/backend_data/liquid_rf_model.joblib
ML_FEEDBACK_TRAIN_LIMIT=1200
ML_FEEDBACK_MAE_PENALTY_PCT=20
ML_FEEDBACK_FLIP_WIN_ON_DEEP_MAE=true
# Phat nhe cac lenh WIN nhung bi am sau roi chi hoi ve gan entry.
ML_FEEDBACK_RECOVERY_PENALTY_ENABLED=true
# Neu MAE% <= -nguong nay thi coi la am sau.
ML_FEEDBACK_RECOVERY_PENALTY_MAE_PCT=10
# Va neu loi cuoi <= nguong nay (% margin) thi giam trong so khi train.
ML_FEEDBACK_RECOVERY_PENALTY_MAX_PNL_PCT=2
# He so giam trong so (0.35 = con 35% suc nang cua mau WIN nay).
ML_FEEDBACK_RECOVERY_PENALTY_WEIGHT_FACTOR=0.35
# Tang trong so cho cac mau WIN "dep": loi kha va khong bi am sau.
ML_FEEDBACK_GOOD_SIGNAL_BOOST_ENABLED=true
# Loi toi thieu (% margin) de duoc xem la mau tot.
ML_FEEDBACK_GOOD_SIGNAL_MIN_PNL_PCT=8
# MAE toi da cho phep (% margin). Vi du 4 = khong bi am qua 4%.
ML_FEEDBACK_GOOD_SIGNAL_MAX_MAE_PCT=4
# He so nhan trong so cho mau WIN tot.
ML_FEEDBACK_GOOD_SIGNAL_WEIGHT_MULTIPLIER=1.4
# Bat/tat trong so mau train theo do lon PnL% (lay tu ml_feedback).
ML_FEEDBACK_USE_PNL_WEIGHT=true
# He so tang trong so theo |PnL%|. Vi du 10% -> +0.2 neu factor=0.02.
ML_FEEDBACK_PNL_WEIGHT_FACTOR=0.02
# Tran tang trong so toi da.
ML_FEEDBACK_PNL_WEIGHT_MAX_BOOST=2.0
# Mau LOSS duoc nhan them he so nay (de phat manh signal xau).
ML_FEEDBACK_PNL_LOSS_BOOST_MULTIPLIER=1.1
# Model test rieng de so sanh (A/B) voi model chinh.
ML_TEST_MODEL_PATH=/Users/thang/Desktop/TEST/binance-scalping-bot/backend/backend_data/rf_model_test.joblib
# true: model test dung them liquidation proxy features; false: chi dung base features.
ML_TEST_USE_LIQUIDATION_FEATURES=true
ML_USE_LIQUIDATION_FEATURES=true
LIQUID_ML_ENABLED=true
#LIQUID_ML_MIN_WIN=0.5
LIQUID_ML_TOP_VOL_DAYS=1
LIQUID_ML_MAX_SYMBOLS=30
LIQUID_ML_TOUCH_TOLERANCE_PCT=0.004
# Nguong do manh "vung thanh ly short" toi thieu de xac nhan lenh SHORT.
LIQUID_ML_SHORT_ZONE_MIN_SCORE=0.012
# He so mo rong do gan vung thanh ly cho SHORT (so voi TOUCH_TOLERANCE_PCT).
LIQUID_ML_SHORT_ZONE_TOUCH_MULTIPLIER=2.0
LIQUID_ML_TRAIN_LIMIT=900
LIQUID_ML_TRAIN_HORIZON=16
LIQUID_ML_TRAIN_RR_RATIO=1.5
WS_PING_INTERVAL_SEC=1.0

MYSQL_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=12345678
MYSQL_DATABASE=trading_bot

#PAPER_TRADE_MIN_WIN=0.5
PAPER_TRADE_QUANTITY=5
PAPER_TRADE_LEVERAGE=5
# Coin lon se dung leverage rieng (vi du 10x).
# Fallback thu cong, se duoc uu tien boi dynamic major neu bat o ben duoi.
PAPER_TRADE_MAJOR_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT
# true: tu dong xac dinh "coin lon" tu DB + model + nen 5m (khong dung list cung).
PAPER_TRADE_MAJOR_DYNAMIC_ENABLED=true
# Chu ky cap nhat danh sach coin lon dong (giay).
PAPER_TRADE_MAJOR_DYNAMIC_REFRESH_SEC=180
# So coin lon giu lai de ap dung leverage/risk rieng.
PAPER_TRADE_MAJOR_DYNAMIC_LIMIT=8
# So ung vien lay tu scan model de cham diem dynamic major.
PAPER_TRADE_MAJOR_DYNAMIC_CANDIDATES=30
# So nen 5m dung de tinh diem thanh khoan/momentum cho dynamic major.
PAPER_TRADE_MAJOR_DYNAMIC_CANDLE_LOOKBACK=24
PAPER_TRADE_MAJOR_LEVERAGE=10
# Tran risk cho nhom coin lon (est. margin ratio %).
PAPER_TRADE_MAJOR_MAX_RISK_PCT=20
#PAPER_TRADE_POLL_INTERVAL_SEC=6

#PAPER_TRADE_MIN_SL_PCT=0.004
PAPER_TRADE_MIN_RR=1.5
#PAPER_TRADE_MAX_TP_PCT=15
PAPER_TRADE_MAX_RISK_PCT=15
PAPER_TRADE_MAX_HOLD_MINUTES=150

# Bat/tat SL tong quat:
# - false: van check SL binh thuong
# - true: bo qua SL, chi con TP/timeout
PAPER_TRADE_DISABLE_SL=false

# Khi loi dat nguong nay (% theo margin), he thong se day SL len muc khoa loi.
PAPER_TRADE_MOVE_SL_TO_ENTRY_PNL_PCT=5

# Sau khi day SL, muc loi toi thieu khoa lai (% theo margin).
PAPER_TRADE_MOVE_SL_LOCK_PNL_PCT=10

# true: nguong dời SL se scale theo leverage.
# Vi du trigger=5 o ref leverage=5 -> lenh 10x se kich hoat o 10%.
PAPER_TRADE_MOVE_SL_SCALE_BY_LEVERAGE=true
PAPER_TRADE_MOVE_SL_REFERENCE_LEVERAGE=5

# Gia tri lenh theo USDT notional (chua nhan leverage).
PAPER_TRADE_ORDER_USDT=100

# Margin co dinh cho moi lenh.
# =0 thi tu tinh tu ORDER_USDT/leverage.
PAPER_TRADE_MARGIN_USDT=20

# Chu ky engine quet mo/quan ly lenh (giay).
PAPER_TRADE_POLL_INTERVAL_SEC=1

# Neu gia WS cu hon nguong nay (giay) thi coi la stale, bo qua va fallback REST.
PAPER_TRADE_STREAM_MAX_STALE_SEC=5

# Slope floor cho SL theo % gia (0.006 = 0.6%).
PAPER_TRADE_MIN_SL_PCT=0.006

# Slope floor cho SL theo % notional.
# Vi du 3.5 = gia cham SL la khoang 3.5% tu entry.
PAPER_TRADE_MIN_SL_LOSS_PCT=3.5

# Buffer them vao khoang cach SL (% theo gia).
PAPER_TRADE_SL_EXTRA_BUFFER_PCT=0.002

# Floor SL theo ATR: ATR * he so nay.
# =0 de tat rang buoc ATR.
PAPER_TRADE_SL_ATR_MULTIPLIER=1.2

# Khung ATR dung de tinh floor SL.
PAPER_TRADE_SL_ATR_TIMEFRAME=5m

# So nen du lieu de tinh ATR.
PAPER_TRADE_SL_ATR_LIMIT=120

# Gioi han TP toi da theo % gia tu entry.
# O leverage 5x, 2% gia ~ 10% ROI margin.
PAPER_TRADE_MAX_TP_PCT=2

# Nguong min win de mo lenh tu model chinh (ML).
PAPER_TRADE_MIN_WIN=0.75

# Nguong min win de mo lenh tu model thanh ly (LIQ_EMA99).
LIQUID_ML_MIN_WIN=0.72

# ===== ML TEST (A/B) =====
# Bat model test de mo lenh rieng (entry_type=ML_TEST) de so sanh voi ML chinh.
PAPER_TRADE_TEST_ML_ENABLED=true

# Nguong min win cho ML_TEST.
PAPER_TRADE_TEST_ML_MIN_WIN=0.75

# So symbol quet cho ML_TEST moi cycle.
PAPER_TRADE_TEST_ML_MAX_SYMBOLS=80

# Gioi han so lenh ML_TEST duoc mo moi vong quet.
PAPER_TRADE_TEST_ML_MAX_ORDERS_PER_CYCLE=2

# ===== BTC regime filter =====
# Bat/tat loc xu huong BTC de chan lenh nguoc trend.
PAPER_TRADE_BTC_FILTER_ENABLED=true

# Khung thoi gian BTC de xac dinh trend loc lenh.
PAPER_TRADE_BTC_FILTER_TIMEFRAME=15m

# Cache trend BTC bao nhieu giay roi tinh lai.
PAPER_TRADE_BTC_FILTER_CACHE_SEC=20

# Do tin cay toi thieu de filter co hieu luc.
PAPER_TRADE_BTC_FILTER_MIN_CONFIDENCE=0.55

# true: chan cung lenh nguoc trend BTC
# false: cho phep neu win prob vuot COUNTERTREND_MIN_WIN
PAPER_TRADE_BTC_FILTER_BLOCK_COUNTERTREND=true

# Chi dung khi BLOCK_COUNTERTREND=false.
PAPER_TRADE_BTC_FILTER_COUNTERTREND_MIN_WIN=0.77

# ===== BTC shock pause =====
# Tam dung mo lenh moi khi BTC bien dong manh.
PAPER_TRADE_BTC_SHOCK_PAUSE_ENABLED=true

# Nguong shock (%), lay max(close-to-close, range nen).
PAPER_TRADE_BTC_SHOCK_THRESHOLD_PCT=1.2

# Sau shock, tam dung mo lenh moi bao nhieu phut.
PAPER_TRADE_BTC_SHOCK_COOLDOWN_MINUTES=30

# Sau shock tang, khoa LENH LONG them X phut (chi mo SHORT/WAIT).
PAPER_TRADE_BTC_SHOCK_UP_LONG_BLOCK_MINUTES=30

# Sau shock giam, khoa LENH SHORT them X phut (chi mo LONG/WAIT).
PAPER_TRADE_BTC_SHOCK_DOWN_SHORT_BLOCK_MINUTES=30

# true: chi mo lai LONG khi BTC pullback ve EMA.
PAPER_TRADE_BTC_SHOCK_UP_REQUIRE_PULLBACK=true

# EMA dung de xac nhan pullback (21 hoac 55).
PAPER_TRADE_BTC_SHOCK_PULLBACK_EMA_PERIOD=21

# Do lech cho phep tren EMA de xem la da pullback.
PAPER_TRADE_BTC_SHOCK_PULLBACK_TOLERANCE_PCT=0.0015

# Tu dong dong lenh LONG dang loi khi BTC dao chieu giam manh.
PAPER_TRADE_BTC_REVERSAL_PROFIT_EXIT_ENABLED=true
# Nguong dao chieu manh (%) de kich hoat dong nhanh.
PAPER_TRADE_BTC_REVERSAL_THRESHOLD_PCT=0.8
# Do tin cay toi thieu cua trend SHORT BTC de cho dong nhanh.
PAPER_TRADE_BTC_REVERSAL_MIN_CONFIDENCE=0.55

# ===== BTC profit-lock (dong lenh dang loi theo trend BTC) =====
# Bat/tat co che: BTC doi trend bat loi -> dong lenh dang loi nguoc trend.
PAPER_TRADE_BTC_PROFIT_LOCK_ENABLED=true

# Do tin cay toi thieu cua trend BTC de kich hoat dong lenh.
PAPER_TRADE_BTC_PROFIT_LOCK_MIN_CONFIDENCE=0.60

# Chi dong voi coin "di theo BTC" (tuong quan duong >= nguong nay).
PAPER_TRADE_BTC_FOLLOW_MIN_CORR=0.45

# Dieu kien beta toi thieu de xac nhan coin di cung huong BTC.
PAPER_TRADE_BTC_FOLLOW_MIN_BETA=0.20

# So nen dung de tinh corr/beta coin voi BTC.
PAPER_TRADE_BTC_FOLLOW_LOOKBACK=120

# Cache ket qua corr/beta moi symbol (giay) de tranh goi API qua nhieu.
PAPER_TRADE_BTC_FOLLOW_CACHE_SEC=300
